# agentdeck config — copy to ~/.config/agentdeck/config and edit.
# Plain shell: KEY=value. All keys are optional; defaults shown.
# Override this file's path with the AGENTDECK_CONFIG environment variable.

# Where per-session state files live.
# AGENTDECK_STATE_DIR="$HOME/.local/state/agentdeck"

# Prune state files untouched for this many seconds (dead/crashed sessions).
# AGENTDECK_TTL=86400

# Desktop banner when a session finishes (Stop). Set 0 to only alert on "waiting".
# AGENTDECK_NOTIFY_ON_STOP=1

# Force a multiplexer backend instead of autodetecting from $ZELLIJ / $TMUX.
# AGENTDECK_MUX=zellij

# ── notifications (macOS; terminal-notifier only — no effect on the osascript
# or notify-send fallbacks) ───────────────────────────────────────────────────

# Click a banner to jump back to the waiting session.
#   auto            detect the host terminal (Ghostty focuses the exact tab;
#                   other terminals come forward; VS Code reuses the project window)
#   ghostty|vscode  force a strategy
#   app:<bundle-id> just activate that app (e.g. app:com.apple.Terminal)
#   off             no click action
# AGENTDECK_NOTIFY_FOCUS=auto

# Borrow another app's notification icon + identity (a bundle id).
# AGENTDECK_NOTIFY_SENDER=com.apple.Terminal

# Path/URL to a custom notification icon image.
# AGENTDECK_NOTIFY_ICON=
