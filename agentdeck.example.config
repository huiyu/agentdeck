# agentdeck config — copy to ~/.config/agentdeck/config and edit.
# Plain shell: KEY=value. All keys are optional; defaults shown.

# Where per-session state files live.
# AGENTDECK_STATE_DIR="$HOME/.local/state/agentdeck"

# Prune state files untouched for this many seconds (dead/crashed sessions).
# AGENTDECK_TTL=86400

# Desktop banner when a session finishes (Stop). Set 0 to only alert on "waiting".
# AGENTDECK_NOTIFY_ON_STOP=1

# Force a multiplexer backend instead of autodetecting from $ZELLIJ / $TMUX.
# AGENTDECK_MUX=zellij
